#:import utils kivy.utils
#:import ProjectCard screens.home.ProjectCard

# Section: Custom clickable container combining Button logic with Box Layout
<ClickableBoxLayout@ButtonBehavior+BoxLayout>:

# Section: Custom clickable container combining Button logic with Anchor Layout
<ClickableAnchorLayout@ButtonBehavior+AnchorLayout>:

# Reusable component for the Text Input (Nazwa Projektu)
<ProjectTextInput@BoxLayout>:
    size_hint_y: None
    height: dp(50)
    padding: dp(15), 0, dp(15), 0
    spacing: dp(10)
    hint_text: ""
    icon_text: ""
    text: ""
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#E8E8E8")
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(3)]

    TextInput:
        text: root.text
        hint_text: root.hint_text
        background_color: 0, 0, 0, 0
        foreground_color: utils.get_color_from_hex("#333333")
        hint_text_color: utils.get_color_from_hex("#777777")
        font_size: sp(16)
        multiline: False
        # Center the text vertically
        padding_y: [self.height / 2.0 - (self.line_height / 2.0) * len(self._lines), 0]
        cursor_color: utils.get_color_from_hex("#8A4AF3")
        on_text: root.text = self.text

    # Slot for the icon, ensuring it is centered vertically and horizontally
    AnchorLayout:
        size_hint_x: None
        width: dp(30)
        MDIcon:
            icon: root.icon_text
            adaptive_size: True
            theme_text_color: "Custom"
            text_color: utils.get_color_from_hex("#555555")
            icon_size: sp(22)

# Visual rule for the emoji icons in the picker dialog
<EmojiButton>:
    size_hint: None, None
    size: dp(60), dp(60)
    canvas.before:
        Color:
            rgba: (0, 0, 0, 0.1) if self.state == 'down' else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]

# Reusable component for the clickable rows (+ Zdjęcie, Wybierz kolor, etc.)
<ProjectButton@ButtonBehavior+BoxLayout>:
    size_hint_y: None
    height: dp(50)
    padding: dp(15), 0, dp(15), 0
    spacing: dp(10)
    text: ""
    icon_text: ""
    preview_source: ""
    preview_icon: ""
    preview_color: [0, 0, 0, 0]
    preview_text: ""
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#E8E8E8")
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(3)]

    Label:
        text: root.text
        color: utils.get_color_from_hex("#777777")
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        font_size: sp(15)
        size_hint_x: 1

    # Preview Area for Image/Color
    BoxLayout:
        size_hint_x: None
        width: self.minimum_width
        spacing: dp(10)
        
        # Text/Emoji Preview within the row
        Label:
            text: root.preview_text
            color: utils.get_color_from_hex("#333333")
            font_size: sp(18)
            size_hint_x: None
            width: self.texture_size[0] if root.preview_text else 0
            opacity: 1 if root.preview_text else 0

        # Color Preview
        Widget:
            size_hint: None, None
            size: (dp(30), dp(30)) if root.preview_color[3] > 0 else (0, 0)
            opacity: 1 if root.preview_color[3] > 0 else 0
            pos_hint: {'center_y': .5}
            canvas.before:
                Color:
                    rgba: root.preview_color
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]

        # Photo Preview Thumbnail
        FitImage:
            source: root.preview_source
            size_hint: None, None
            size: (dp(40), dp(40)) if root.preview_source else (0, 0)
            opacity: 1 if root.preview_source else 0
            pos_hint: {'center_y': .5}
            radius: [dp(5), ]

        # Icon Preview within the selection row
        
        FitImage:
            source: root.preview_icon if root.preview_icon.endswith('.png') else ""
            size_hint: None, None
            size: (dp(35), dp(35)) if root.preview_icon.endswith('.png') else (0, 0)
            opacity: 1 if root.preview_icon.endswith('.png') else 0
            pos_hint: {'center_y': .5}
            radius: [dp(4),]

        MDIcon:
            icon: root.preview_icon if not root.preview_icon.endswith('.png') else ""
            theme_text_color: "Custom"
            text_color: utils.get_color_from_hex("#333333")
            icon_size: sp(22)
            size_hint: None, None
            size: (dp(35), dp(35)) if root.preview_icon and not root.preview_icon.endswith('.png') else (0, 0)
            opacity: 1 if root.preview_icon and not root.preview_icon.endswith('.png') else 0
            pos_hint: {'center_y': .5}

    # Slot for the icon, ensuring it is centered vertically and horizontally
    AnchorLayout:
        size_hint_x: None
        width: dp(30)
        MDIcon:
            icon: root.icon_text
            adaptive_size: True
            theme_text_color: "Custom"
            text_color: utils.get_color_from_hex("#444444")
            icon_size: sp(20)

# Section: Add Project Screen definition
<AddProjectScreen>:
    # Main screen background color
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#8A4BF4") # Primary Purple Background
        Rectangle:
            pos: self.pos
            size: self.size

    # Main layout with ScrollView to support large previews
    MDBoxLayout:
        orientation: "vertical"
        padding: dp(30), dp(40), dp(30), dp(10)
        spacing: dp(15)

        # Header Area
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            ClickableAnchorLayout:
                size_hint_x: None
                width: dp(30)
                on_release: app.root.current = "home"
                MDIcon:
                    icon: "chevron-left"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    icon_size: sp(28)
                    adaptive_size: True
            Label:
                text: "Dodawanie projektu"
                font_size: sp(20)
                bold: True
                halign: 'center'
            Widget:
                size_hint_x: None
                width: dp(30)

        ScrollView:
            do_scroll_x: False
            MDBoxLayout:
                orientation: 'vertical'
                adaptive_height: True
                spacing: dp(20)
                padding: [0, dp(30), 0, dp(100)] # Top padding prevents emoji clipping

                # Section: Live Preview of the Project Card
                ProjectCard:
                    id: preview_card
                    size_hint: 0.95, None
                    height_multiplier: 1 # Taller ratio to fit large photo
                    pos_hint: {'center_x': 0.5}
                    title: project_name_input.text if project_name_input.text else "Tytuł Projektu"
                    image_source: root.selected_image_path
                    emoji_source: root.selected_icon
                    card_color: root.selected_color
                    title_font_style: "H5"
                    emoji_size: dp(80)

                # Form Fields
                ProjectTextInput:
                    id: project_name_input
                    hint_text: "Nazwa Projektu"
                    icon_text: "close-circle-outline"

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    spacing: dp(15)
                    ProjectButton:
                        text: "Kolor"
                        icon_text: "palette"
                        on_release: root.select_color()
                    ProjectButton:
                        text: "Emotka"
                        icon_text: "emoticon-happy-outline"
                        preview_icon: root.selected_icon
                        on_release: root.select_emoji()

                ProjectButton:
                    text: "+ Zdjęcie"
                    icon_text: "image-plus"
                    on_release: root.select_photo()

    # Section: Floating Action Button (Confirm/Save action)
    ClickableAnchorLayout:
        # Centering and sizing the action button to match the Home screen style
        size_hint: None, None
        size: dp(140), dp(65)
        pos_hint: {'center_x': 0.5, 'y': 0.05}
        on_release: root.save_project()
        canvas.before:
            # Visual styling for the FAB rounded rectangle
            Color:
                rgba: utils.get_color_from_hex("#F3E9FF")
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(20)]
        MDIcon:
            icon: "check"
            # Adjusted to a large size that fits within the button height
            icon_size: sp(50)
            theme_text_color: "Custom"
            text_color: utils.get_color_from_hex("#333333")
            adaptive_size: True