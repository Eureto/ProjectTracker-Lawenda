#:import utils kivy.utils
#:import ProjectCard screens.home.ProjectCard

# Section: Custom clickable container combining Button logic with Box Layout
<ClickableBoxLayout@ButtonBehavior+BoxLayout>:

# Section: Custom clickable container combining Button logic with Anchor Layout
<ClickableAnchorLayout@ButtonBehavior+AnchorLayout>:

# ──────────────────────────────────────────────
# Reusable: Project Name Text Input
# ──────────────────────────────────────────────
<ProjectTextInput@BoxLayout>:
    size_hint_y: None
    height: dp(54)
    padding: dp(15), 0, dp(15), 0
    spacing: dp(10)
    hint_text: ""
    icon_text: ""
    text: ""
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#EFEFEF")
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

    TextInput:
        text: root.text
        hint_text: root.hint_text
        background_color: 0, 0, 0, 0
        foreground_color: utils.get_color_from_hex("#222222")
        hint_text_color: utils.get_color_from_hex("#AAAAAA")
        font_size: sp(16)
        multiline: False
        padding_y: [self.height / 2.0 - (self.line_height / 2.0) * len(self._lines), 0]
        cursor_color: utils.get_color_from_hex("#8A4AF3")
        on_text: root.text = self.text

    AnchorLayout:
        size_hint_x: None
        width: dp(30)
        MDIcon:
            icon: root.icon_text
            adaptive_size: True
            theme_text_color: "Custom"
            text_color: utils.get_color_from_hex("#AAAAAA")
            icon_size: sp(22)

# ──────────────────────────────────────────────
# Reusable: Square tile button (Zdjęcie / Kolor / Emoji)
# ──────────────────────────────────────────────
<ProjectTileButton@ButtonBehavior+BoxLayout>:
    orientation: "vertical"
    size_hint_y: None
    height: dp(80)
    padding: dp(8)
    spacing: dp(6)
    label_text: ""
    icon_text: ""
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#EFEFEF")
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

    Label:
        text: root.label_text
        color: utils.get_color_from_hex("#777777")
        font_size: sp(13)
        size_hint_y: None
        height: dp(20)
        halign: "center"
        valign: "middle"
        text_size: self.size

    AnchorLayout:
        size_hint_y: 1
        MDIcon:
            icon: root.icon_text
            adaptive_size: True
            theme_text_color: "Custom"
            text_color: utils.get_color_from_hex("#555555")
            icon_size: sp(26)

# ──────────────────────────────────────────────
# Emoji picker button (used inside dialog)
# ──────────────────────────────────────────────
<EmojiButton>:
    size_hint: None, None
    size: dp(60), dp(60)
    canvas.before:
        Color:
            rgba: (0, 0, 0, 0.1) if self.state == 'down' else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]

# ──────────────────────────────────────────────
# Add Project Screen
# ──────────────────────────────────────────────
<AddProjectScreen>:
    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#8A4BF4")
        Rectangle:
            pos: self.pos
            size: self.size

    # ── Main vertical layout ──
    MDBoxLayout:
        orientation: "vertical"
        padding: dp(24), dp(44), dp(24), dp(0)
        spacing: dp(0)

        # ── Header ──
        BoxLayout:
            size_hint_y: None
            height: dp(44)
            spacing: dp(0)

            ClickableAnchorLayout:
                size_hint_x: None
                width: dp(36)
                anchor_x: "left"
                on_release: app.root.current = "home"
                MDIcon:
                    icon: "chevron-left"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    icon_size: sp(30)
                    adaptive_size: True

            Label:
                text: "Dodawanie projektu"
                font_size: sp(20)
                bold: True
                color: 1, 1, 1, 1
                halign: "center"
                valign: "middle"
                text_size: self.size

            Widget:
                size_hint_x: None
                width: dp(36)

        # ── Scrollable body ──
        ScrollView:
            do_scroll_x: False
            size_hint_y: 1

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: dp(18)
                padding: [0, dp(24), 0, dp(120)]

                # ── Preview card ──
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(290)
                    spacing: dp(8)
                    padding: [0, dp(30), 0, 0]

                    AnchorLayout:
                        size_hint_y: None
                        height: dp(230)
                        anchor_x: "center"
                        anchor_y: "center"

                        ProjectCard:
                            id: preview_card
                            size_hint: None, None
                            width: dp(200)
                            height: dp(220)
                            height_multiplier: 1
                            title: project_name_input.text if project_name_input.text else "Tytuł Projektu"
                            image_source: root.selected_image_path
                            emoji_source: root.selected_icon
                            card_color: root.selected_color
                            title_font_style: "H6"
                            emoji_size: dp(72)

                    # "Podgląd" label below card
                    Label:
                        text: "Podgląd"
                        font_size: sp(14)
                        color: utils.get_color_from_hex("#DDD0FF")
                        size_hint_y: None
                        height: dp(22)
                        halign: "center"
                        valign: "middle"
                        text_size: self.size

                # ── Project name input ──
                ProjectTextInput:
                    id: project_name_input
                    hint_text: "Nazwa Projektu"
                    icon_text: "close-circle-outline"

                # ── Three tile buttons ──
                BoxLayout:
                    size_hint_y: None
                    height: dp(80)
                    spacing: dp(12)

                    ProjectTileButton:
                        label_text: "+ Zdjęcie"
                        icon_text: "image-outline"
                        on_release: root.select_photo()

                    ProjectTileButton:
                        label_text: "+ Kolor"
                        icon_text: "palette-outline"
                        on_release: root.select_color()

                    ProjectTileButton:
                        label_text: "+ Emoji"
                        icon_text: "emoticon-happy-outline"
                        on_release: root.select_emoji()

    # ── Floating confirm button (circle) ──
    ClickableAnchorLayout:
        size_hint: None, None
        size: dp(68), dp(68)
        pos_hint: {"center_x": 0.5, "y": 0.04}
        on_release: root.save_project()
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex("#F3EAFF")
            Ellipse:
                pos: self.pos
                size: self.size
        MDIcon:
            icon: "check"
            icon_size: sp(34)
            theme_text_color: "Custom"
            text_color: utils.get_color_from_hex("#333333")
            adaptive_size: True
