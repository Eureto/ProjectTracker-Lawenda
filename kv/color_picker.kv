<ColorPickerContent>:
    canvas.before:
        Color:
            rgba: 0.12, 0.12, 0.12, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(16)]

    MDLabel:
        text: "Wybierz kolor"
        font_style: "H5"
        bold: True
        size_hint_y: None
        height: dp(36)
        halign: "center"
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        padding: [0, dp(8), 0, 0]

    MDFloatLayout:
        size_hint_y: None
        height: dp(260)
        HsvWheel:
            id: hsv_wheel
            color_hex: root.color_hex
            size_hint: None, None
            size: dp(240), dp(240)
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            on_color_hex: root._on_wheel_color(self)

    MDBoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: dp(48)
        spacing: dp(12)
        padding: [dp(8), 0]

        MDLabel:
            text: "Jasność"
            size_hint_x: None
            width: dp(60)
            font_size: dp(14)
            halign: "left"
            valign: "middle"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 0.8

        MDSlider:
            id: brightness_slider
            min: 0.05
            max: 1.0
            value: root._val
            size_hint_x: 1
            on_value: root._on_brightness(self, args[1])

    MDBoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: dp(56)
        spacing: dp(12)
        padding: [dp(8), dp(4)]

        MDTextField:
            id: hex_input
            text: root.color_hex.upper()
            hint_text: "#FF0000"
            helper_text: "Hex kolor (np. #FF0000)"
            helper_text_mode: "on_focus"
            size_hint_x: 0.6
            max_text_length: 7
            text_color_normal: 1, 1, 1, 0.9
            text_color_focus: 1, 1, 1, 1
            line_color_normal: 1, 1, 1, 0.4
            line_color_focus: 1, 1, 1, 0.8
            hint_text_color_normal: 1, 1, 1, 0.5
            hint_text_color_focus: 1, 1, 1, 0.7
            helper_text_color_normal: 1, 1, 1, 0.5
            helper_text_color_focus: 1, 1, 1, 0.7
            on_text_validate: root._on_hex_text(self.text)
            on_focus: if not self.focus: root._on_hex_text(self.text)

        Widget:
            id: preview_rect
            size_hint_x: 0.35
            size_hint_y: None
            height: dp(44)
