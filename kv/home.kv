#:import utils kivy.utils
#:import DotProgressBar screens.home.DotProgressBar
#:import ProjectCard screens.home.ProjectCard
#:import SessionCard screens.home.SessionCard

# Section: Custom clickable container combining Button logic with Box Layout
<ClickableBoxLayout@ButtonBehavior+BoxLayout>:

# Section: Custom clickable container combining Button logic with Anchor Layout
<ClickableAnchorLayout@ButtonBehavior+AnchorLayout>:

# Section: Custom widget for displaying a sequence of dots as a progress bar
<DotProgressBar>:
    size_hint_y: None
    height: dp(20)

# Section: Visual representation of a single project card
<ProjectCard>:
    size_hint: 0.4, None
    height: self.width * self.height_multiplier
    radius: [dp(24), ]
    md_bg_color: root.card_color
    elevation: 2
    padding: dp(10)

    canvas.before:
        PushMatrix
        Rotate:
            angle: self.angle
            origin: self.center
    canvas.after:
        PopMatrix

    MDRelativeLayout:

        # ── Full-card image (inset by padding, inner radius slightly smaller) ──
        FitImage:
            source: root.image_source
            size_hint: 1, 1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            fit_mode: "contain"
            radius: [dp(16), ]

        # ── Title panel — full width, card color, bottom of image ──
        MDBoxLayout:
            size_hint: 1, None
            height: dp(38)
            pos_hint: {'center_x': 0.5, 'y': 0}
            padding: dp(8), 0
            canvas.before:
                Color:
                    rgba: root.card_color
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(16), dp(16), dp(16), dp(16)]

            MDLabel:
                text: root.title
                font_style: root.title_font_style
                bold: True
                halign: "center"
                valign: "middle"
                theme_text_color: "Custom"
                text_color: root.title_text_color
                shorten: True
                shorten_from: "right"

        # ── Emoji badge — top-right corner, rotated -30°, scaled up ──
        MDIcon:
            icon: root.emoji_source
            size_hint: None, None
            size: root.emoji_size * 1.6, root.emoji_size * 1.6
            font_size: root.emoji_size * 1.6
            icon_size: root.emoji_size * 1.6
            pos_hint: {'right': 1.05, 'top': 1.25}
            theme_text_color: "Custom"
            text_color: (1, 1, 1, 1) if root.emoji_source.endswith('.png') else (1, 0.8, 0, 1)
            canvas.before:
                PushMatrix
                Rotate:
                    angle: -30
                    origin: self.center
            canvas.after:
                PopMatrix

# Section: Last session — light outer frame, dark inner box (box-in-box)
<SessionCard>:
    size_hint: 0.9, None
    height: dp(129)
    radius: [dp(22), dp(22), dp(22), dp(22)]
    md_bg_color: utils.get_color_from_hex(app.theme_session_header)
    elevation: 4
    padding: [0, dp(12), 0, 0]
    orientation: "vertical"
    spacing: dp(8)

    # Header sits in the light outer frame (above inner box)
    MDBoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: dp(22)
        padding: [dp(14), 0, dp(14), 0]
        spacing: dp(8)

        MDLabel:
            text: "Ostatnia sesja"
            bold: True
            font_style: "Caption"
            font_size: sp(13)
            halign: "left"
            valign: "middle"
            theme_text_color: "Custom"
            text_color: utils.get_color_from_hex(app.theme_text_dark)
            size_hint_x: 1
            text_size: self.width, None

        MDLabel:
            text: root.when_label if root.has_session else "—"
            bold: True
            font_style: "Caption"
            font_size: sp(13)
            halign: "right"
            valign: "middle"
            theme_text_color: "Custom"
            text_color: utils.get_color_from_hex(app.theme_text_dark)
            size_hint_x: None

    # Inner dark box — flush left/right/bottom with outer card
    MDCard:
        orientation: "vertical"
        size_hint_x: 1
        size_hint_y: 1
        radius: [dp(22), dp(22), dp(22), dp(22)]
        md_bg_color: utils.get_color_from_hex(app.theme_session_bg)
        elevation: 0
        padding: [dp(14), dp(9), dp(14), dp(14)]
        spacing: dp(10)

        FloatLayout:
            size_hint_x: 1
            size_hint_y: None
            height: dp(38)

            MDLabel:
                id: session_project_title
                text: root.project_name if root.has_session else "Brak ostatniej sesji"
                font_style: "H6"
                bold: True
                font_size: sp(22)
                halign: "right"
                valign: "middle"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint: 1, 1
                pos_hint: {"x": 0, "y": 0}
                padding: 0, 0
                text_size: self.width, None
                shorten: True
                shorten_from: "right"

            MDIcon:
                id: session_project_icon
                icon: root.emoji_source
                theme_text_color: "Custom"
                text_color: (1, 1, 1, 1) if root.emoji_source.endswith('.png') else (1, 0.8, 0, 1)
                icon_size: dp(26)
                size_hint: None, None
                size: dp(28), dp(28)
                opacity: 1 if root.has_session else 0.45

        MDLabel:
            text: root.duration_text if root.has_session else "Uruchom timer w projekcie"
            halign: "right"
            valign: "middle"
            font_style: "Caption"
            font_size: sp(14)
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 0.95 if root.has_session else 0.65
            size_hint_x: 1
            size_hint_y: None
            height: dp(20)
            padding: 0, 0
            text_size: self.width, None
            shorten: True
            shorten_from: "left"

# Section: Main Dashboard Screen
<HomeScreen>:
    md_bg_color: utils.get_color_from_hex(app.theme_bg)

    MDBoxLayout:
        orientation: 'vertical'
        spacing: dp(10)
        
        # Spacer for system status bar
        Widget:
            size_hint_y: None
            height: dp(35) 
            
        MDFloatLayout:
            size_hint_y: None
            height: dp(70)
            canvas.after:
                Color:
                    rgba: 1, 1, 1, 1
                Line:
                    points: [self.x, self.y, self.right, self.y]
                    width: dp(1.5)
            
            # App Branding/Title
            MDLabel:
                text: "JUST DO IT"
                font_style: "H4"
                bold: True
                halign: "center"
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                
            # Layout/Grid toggle button
            MDIconButton:
                icon: "view-grid"
                pos_hint: {'right': 0.98, 'center_y': 0.5}
                theme_text_color: "Custom"
                text_color: (1, 1, 0, 1) if app.grid_layout else (1, 1, 1, 1)
                on_release: app.toggle_layout_menu()

        # Fixed SessionCard that stays on top of the list and doesn't scroll
        SessionCard:
            id: last_session_card
            pos_hint: {'center_x': 0.5}

        # Main scrollable list of content
        ScrollView:
            do_scroll_x: False
            
            MDFloatLayout:
                id: projects_container
                size_hint_y: None
                height: dp(1)
               
    # Section: Bottom Navigation and Global Actions
    MDFloatLayout:
        size_hint: 1, None
        height: dp(60)
        pos_hint: {'center_x': 0.5, 'y': 0}
        
        # Main Bottom Navbar — flush left/right/bottom; rounded top only
        MDCard:
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}
            radius: [dp(25), dp(25), 0, 0]
            elevation: 4
            md_bg_color: 1, 1, 1, 1
            
            MDBoxLayout:
                # We use three equal slots to distribute the icons to the centers of the outer thirds
                AnchorLayout:
                    anchor_x: 'center'
                    anchor_y: 'center'
                    MDIconButton:
                        icon: "home-outline"
                        icon_size: dp(30)

                # Middle slot: Empty to provide space for the Floating Action Button
                Widget:

                AnchorLayout:
                    anchor_x: 'center'
                    anchor_y: 'center'
                    MDIconButton:
                        icon: "chart-arc"
                        icon_size: dp(30)
                        on_release: app.root.current = "statistics"

        # Section: Global Floating Action Button (Add Project/Session)
        # We use ClickableAnchorLayout to center the icon perfectly within the rectangle
        ClickableAnchorLayout:
            size_hint: None, None
            size: dp(120), dp(56)
            pos_hint: {'center_x': 0.5, 'center_y': 0.67}
            on_release: app.root.current = "add_project"
            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex(app.theme_card_bg)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(18)]
            
            Label:
                text: "+"
                bold: True
                font_size: dp(48)
                color: 1, 1, 1, 1
                halign: "center"
                valign: "middle"
                size_hint: None, None
                pos_hint: {"center_x": 0.5, "center_y": 0.5}