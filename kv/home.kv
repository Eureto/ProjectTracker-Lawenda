<ActivityCard@MDCard>: # Defines a custom widget named ActivityCard, inheriting from MDCard.
    image: "" # Custom property for the image source.
    text: "" # Custom property for the text to display.
    orientation: 'vertical' # Arranges children vertically.
    radius: 30 # Sets the corner radius of the card.
    elevation: 2 # Adds a shadow effect to the card.
    padding: 0 # No internal padding.
    spacing: 0 # No spacing between children.

    RelativeLayout: # A layout that allows children to be positioned relative to each other or the parent.
        FitImage: # A custom image widget that fits the image within its bounds.
            source: root.image # Binds the image source to the ActivityCard's image property.
            radius: [30, 30, 30, 30] # Sets the corner radius of the image.
        
        MDCard: # An MDCard nested within the RelativeLayout.
            size_hint: (0.8, 0.3) # Sets the size of the card relative to its parent (80% width, 30% height).
            pos_hint: {"center_x": .5, "center_y": .5} # Centers the card horizontally and vertically within its parent.
            radius: 20 # Sets the corner radius of this inner card.
            md_bg_color: 0.7, 0.5, 0.9, 1 # Sets the background color of the card (RGBA values).
            
            MDLabel: # A Material Design label to display text.
                text: root.text # Binds the label's text to the ActivityCard's text property.
                halign: "center" # Horizontally aligns the text to the center.
                theme_text_color: "Primary" # Uses the primary text color from the KivyMD theme.
                font_style: "Caption" # Sets the font style to "Caption".
                bold: True # Makes the text bold.

<HomeScreen>: # Defines the main screen widget, inheriting from a KivyMD screen (implied by context).
    md_bg_color: 0.58, 0.28, 0.94, 1 # Sets the background color of the screen.

    MDBoxLayout: # A Material Design Box Layout for arranging widgets.
        orientation: 'vertical' # Arranges children vertically.
        padding: [20, 20, 20, 0] # Sets padding around the layout (left, top, right, bottom).
        spacing: 15 # Sets spacing between children.

        # Górna sekcja: Logo i Plus (Top section: Logo and Plus)
        MDBoxLayout: # A horizontal box layout for the header.
            size_hint_y: None # Disables vertical size hinting, allowing explicit height.
            height: "80dp" # Sets the height of the header.
            
            Image: # An image widget for the logo.
                source: "https://via.placeholder.com/150/8A4AF3/FFFFFF?text=Logo" # Source URL for the logo image.
                size_hint_x: 0.3 # Sets the width of the image to 30% of the parent's width.
            
            Widget: # A blank widget used as a spacer to push the icon button to the right.
            
            MDIconButton: # A Material Design icon button.
                icon: "plus" # Sets the icon to a "plus" symbol.
                icon_size: "64sp" # Sets the size of the icon.
                theme_icon_color: "Custom" # Allows custom icon color.
                icon_color: 1, 1, 1, 1 # Sets the icon color to white.
                on_release: root.plus_button_pressed() # Calls the plus_button_pressed method on release.

        # Cytat (Quote)
        MDLabel: # A Material Design label for displaying a quote.
            text: "Super motywujący cytat!!!" # The text of the quote.
            halign: "center" # Horizontally aligns the text to the center.
            size_hint_y: None # Disables vertical size hinting.
            height: "40dp" # Sets the height of the label.
            theme_text_color: "Custom" # Allows custom text color.
            text_color: 1, 1, 1, 1 # Sets the text color to white.
            font_style: "H5" # Sets the font style to "H5".

        MDSeparator: # A Material Design separator line.
            color: 1, 1, 1, 0.5 # Sets the color of the separator (white with 50% opacity).

        # Siatka z aktywnościami (Grid of activities)
        MDGridLayout: # A Material Design Grid Layout.
            cols: 2 # Sets the number of columns to 2.
            spacing: 15 # Sets spacing between grid cells.
            padding: [0, 10, 0, 10] # Sets padding around the grid (left, top, right, bottom).
            
            ActivityCard: # An instance of the custom ActivityCard widget.
                text: "Nauka Chińskiego" # Sets the text for this card.
                image: "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=400&q=80" # Sets the image for this card.
            
            ActivityCard: # Another instance of ActivityCard.
                text: "Taniec" # Sets the text for this card.
                image: "https://images.unsplash.com/photo-1508700115892-45ecd05ae2ad?auto=format&fit=crop&w=400&q=80" # Sets the image for this card.
                
            ActivityCard: # Another instance of ActivityCard.
                text: "Nauka Chińskiego" # Sets the text for this card.
                image: "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=400&q=80" # Sets the image for this card.
            
            ActivityCard: # Another instance of ActivityCard.
                text: "Taniec" # Sets the text for this card.
                image: "https://images.unsplash.com/photo-1508700115892-45ecd05ae2ad?auto=format&fit=crop&w=400&q=80" # Sets the image for this card.

        # Sekcja "Ostatnia sesja" (Last session section)
        MDCard: # A Material Design card for displaying the last session.
            size_hint_y: None # Disables vertical size hinting.
            height: "160dp" # Sets the height of the card.
            radius: 35 # Sets the corner radius.
            md_bg_color: 0.7, 0.5, 0.9, 1 # Sets the background color.
            padding: [15, 10, 15, 15] # Sets internal padding.
            orientation: 'vertical' # Arranges children vertically.
            
            MDLabel: # Label for "Ostatnia sesja".
                text: "Ostatnia sesja" # Text of the label.
                font_style: "Caption" # Font style.
                theme_text_color: "Primary" # Text color from theme.
                size_hint_y: None # Disables vertical size hinting.
                height: "20dp" # Sets the height.
            
            MDCard: # Inner card for session details.
                radius: 20 # Corner radius.
                md_bg_color: 0.85, 0.85, 0.85, 1 # Background color.
                padding: 10 # Internal padding.
                orientation: 'vertical' # Arranges children vertically.
                
                MDBoxLayout: # Box layout for project name and time.
                    adaptive_height: True # Adapts height to content.
                    spacing: 5 # Spacing between children.
                    MDIcon: # Icon for play.
                        icon: "play-outline" # Play icon.
                        size_hint: (None, None) # Disables size hinting.
                        size: "20dp", "20dp" # Sets explicit size.
                    MDLabel: # Label for project name and time.
                        text: "Nazwa Projektu   HH:MM" # Placeholder text.
                        font_style: "Caption" # Font style.
                        valign: "middle" # Vertically aligns text to middle.
                
                # Własny widget Timeline zastępujący statyczny obrazek (Custom TimelineWidget replacing static image)
                TimelineWidget: # A custom widget for a timeline.
                    size_hint_y: 1 # Takes up all available vertical space.

        Widget: # A blank widget used as a spacer.

    # Dolny pasek nawigacji (Bottom navigation bar)
    MDBoxLayout: # Box layout for the navigation bar.
        size_hint_y: None # Disables vertical size hinting.
        height: "80dp" # Sets the height.
        md_bg_color: 0.85, 0.85, 0.85, 1 # Background color.
        padding: [50, 0, 50, 0] # Internal padding.
        
        MDIconButton: # Navigation icon button.
            icon: "circle" # Circle icon.
            icon_size: "48sp" # Icon size.
            theme_icon_color: "Custom" # Allows custom icon color.
            icon_color: 0, 0, 0, 1 # Black icon color.
            pos_hint: {"center_y": .5} # Centers vertically.

        Widget: # Spacer widget.

        MDIconButton: # Another navigation icon button.
            icon: "circle" # Circle icon.
            icon_size: "48sp" # Icon size.
            theme_icon_color: "Custom" # Allows custom icon color.
            icon_color: 0, 0, 0, 1 # Black icon color.
            pos_hint: {"center_y": .5} # Centers vertically.
