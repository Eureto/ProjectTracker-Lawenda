#:import utils kivy.utils
#:import DotProgressBar screens.home.DotProgressBar
#:import ProjectCard screens.home.ProjectCard
#:import SessionCard screens.home.SessionCard

# Section: Custom clickable container combining Button logic with Box Layout
<ClickableBoxLayout@ButtonBehavior+BoxLayout>:

# Section: Custom clickable container combining Button logic with Anchor Layout
<ClickableAnchorLayout@ButtonBehavior+AnchorLayout>:

# Section: Custom widget for displaying a sequence of dots as a progress bar
<DotProgressBar>:
    size_hint_y: None
    height: dp(20)

# Section: Visual representation of a single project card
<ProjectCard>:
    size_hint: 0.4, None
    height: self.width * self.height_multiplier
    radius: [dp(24), ]
    md_bg_color: root.card_color if not app.edit_mode else utils.get_color_from_hex("#FFCDD2")
    elevation: 2
    padding: dp(10)

    canvas.before:
        PushMatrix
        Rotate:
            angle: self.angle
            origin: self.center
    canvas.after:
        PopMatrix

    MDRelativeLayout:

        # ── Full-card image (inset by padding, inner radius slightly smaller) ──
        FitImage:
            source: root.image_source
            size_hint: 1, 1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            radius: [dp(16), ]

        # ── Title panel — full width, card color, bottom of image ──
        MDBoxLayout:
            size_hint: 1, None
            height: dp(38)
            pos_hint: {'center_x': 0.5, 'y': 0}
            padding: dp(8), 0
            canvas.before:
                Color:
                    rgba: root.card_color if not app.edit_mode else utils.get_color_from_hex("#FFCDD2")
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(16), dp(16), dp(16), dp(16)]

            MDLabel:
                text: root.title
                font_style: root.title_font_style
                bold: True
                halign: "center"
                valign: "middle"
                theme_text_color: "Custom"
                text_color: utils.get_color_from_hex("#1A1A1A")
                shorten: True
                shorten_from: "right"

        # ── Emoji badge — top-right corner, rotated -30°, scaled up ──
        MDIcon:
            icon: root.emoji_source
            size_hint: None, None
            size: root.emoji_size * 1.6, root.emoji_size * 1.6
            font_size: root.emoji_size * 1.6
            icon_size: root.emoji_size * 1.6
            pos_hint: {'right': 1.15, 'top': 1.18}
            theme_text_color: "Custom"
            text_color: (1, 1, 1, 1) if root.emoji_source.endswith('.png') else (1, 0.8, 0, 1)
            canvas.before:
                PushMatrix
                Rotate:
                    angle: -30
                    origin: self.center
            canvas.after:
                PopMatrix

# Section: Card showing details of the most recent time tracking session
<SessionCard>:
    size_hint: 0.9, None
    height: dp(140)
    radius: [dp(24), ]
    md_bg_color: utils.get_color_from_hex(app.theme_session_bg)
    elevation: 3
    padding: dp(15)
    orientation: 'vertical'
    
    # Header: Session context labels
    MDRelativeLayout:
        size_hint_y: None
        height: dp(20)
        MDLabel:
            text: "Ostatnia sesja"
            bold: True
            font_style: "Caption"
            halign: "left"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
        MDLabel:
            text: "Wczoraj"
            bold: True
            font_style: "Caption"
            halign: "right"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            
    # Session Info: Project icon and name
    MDBoxLayout:
        spacing: dp(10)
        size_hint_y: None
        height: dp(40)
        MDIcon:
            icon: "crown"
            theme_text_color: "Custom"
            text_color: 1, 0.8, 0, 1
        MDLabel:
            text: "Nazwa Projektu"
            font_style: "H6"
            bold: True
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
                
    # Elapsed time display
    MDLabel:
        text: "Czas:  01:12:53"
        halign: "right"
        font_style: "Caption"
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        
    # Progress tracking within the session card
    DotProgressBar:
        size_hint_x: 1
        total_steps: 5
        current_step: 2

# Section: Main Dashboard Screen
<HomeScreen>:
    md_bg_color: utils.get_color_from_hex(app.theme_bg)

    MDBoxLayout:
        orientation: 'vertical'
        spacing: dp(10)
        
        # Spacer for system status bar
        Widget:
            size_hint_y: None
            height: dp(35) 
            
        MDFloatLayout:
            size_hint_y: None
            height: dp(70)
            canvas.after:
                Color:
                    rgba: 1, 1, 1, 1
                Line:
                    points: [self.x, self.y, self.right, self.y]
                    width: dp(1.5)
            
            # App Branding/Title
            MDLabel:
                text: "JUST DO IT"
                font_style: "H4"
                bold: True
                halign: "center"
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                
            # Layout/Grid toggle button
            MDIconButton:
                icon: "view-grid"
                pos_hint: {'right': 0.98, 'center_y': 0.5}
                theme_text_color: "Custom"
                text_color: (1, 1, 0, 1) if app.edit_mode else (1, 1, 1, 1)
                on_release: app.toggle_layout_menu()

        # Fixed SessionCard that stays on top of the list and doesn't scroll
        SessionCard:
            id: last_session_card
            pos_hint: {'center_x': 0.5}

        # Main scrollable list of content
        ScrollView:
            do_scroll_x: False
            
            MDFloatLayout:
                id: projects_container
                size_hint_y: None
                height: dp(1000) # Initial large height
               
    # Section: Bottom Navigation and Global Actions
    MDFloatLayout:
        size_hint: 1, None
        height: dp(90)
        pos_hint: {'center_x': 0.5, 'y': 0}
        
        # Main Bottom Navbar
        MDCard:
            size_hint: 0.96, 0.75
            pos_hint: {'center_x': 0.5, 'y': 0.1}
            radius: [dp(25), ]
            elevation: 4
            md_bg_color: 1, 1, 1, 1
            
            MDBoxLayout:
                # We use three equal slots to distribute the icons to the centers of the outer thirds
                AnchorLayout:
                    anchor_x: 'center'
                    anchor_y: 'center'
                    MDIconButton:
                        icon: "home-outline"
                        icon_size: dp(45)

                # Middle slot: Empty to provide space for the Floating Action Button
                Widget:

                AnchorLayout:
                    anchor_x: 'center'
                    anchor_y: 'center'
                    MDIconButton:
                        icon: "chart-arc"
                        icon_size: dp(45)

        # Section: Global Floating Action Button (Add Project/Session)
        # We use ClickableAnchorLayout to center the icon perfectly within the rectangle
        ClickableAnchorLayout:
            size_hint: None, None
            size: dp(140), dp(65)
            pos_hint: {'center_x': 0.5, 'center_y': 0.65}
            on_release: app.root.current = "add_project"
            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex(app.theme_card_bg)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(20)]
            
            MDIcon:
                icon: "plus"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                icon_size: dp(55)
                adaptive_size: True