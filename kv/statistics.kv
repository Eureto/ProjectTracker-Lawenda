#:import utils kivy.utils
#:import PieChart screens.statistics.PieChart
#:import PeriodSegmentButton screens.statistics.PeriodSegmentButton
#:import StatisticsDetailRow screens.statistics.StatisticsDetailRow

<StatisticsDetailRow>:
    MDBoxLayout:
        orientation: "horizontal"
        spacing: dp(8)
        size_hint_x: 1
        MDIcon:
            icon: root.icon_name
            theme_text_color: "Custom"
            text_color: root.icon_rgba
            size_hint: None, None
            size: dp(28), dp(28)
            pos_hint: {"center_y": 0.5}
            padding: [0,0,10,0]
        MDLabel:
            text: root.project_name
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            valign: "middle"
            shorten: True
            shorten_from: "right"
            size_hint_x: 1
    AnchorLayout:
        size_hint_x: 1
        anchor_x: "center"
        anchor_y: "center"
        Widget:
            id: segment_dot
            size_hint: None, None
            size: dp(20), dp(20)
    MDLabel:
        text: root.time_text
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        size_hint_x: None
        width: dp(76)
        halign: "right"
        valign: "middle"

<StatisticsScreen>:
    md_bg_color: utils.get_color_from_hex(app.theme_bg)

    MDBoxLayout:
        orientation: 'vertical'
        spacing: dp(10)

        Widget:
            size_hint_y: None
            height: dp(35)

        ScrollView:
            do_scroll_x: False
            bar_width: dp(4)
            padding: 0, 0, 0, 0

            GridLayout:
                id: stats_scroll_content
                cols: 1
                spacing: dp(16)
                padding: [dp(12), dp(2), dp(12), dp(12)]
                size_hint_y: None
                height: self.minimum_height

                # --- Period: vertical pills; selected = white (PeriodSegmentButton) ---
                MDCard:
                    size_hint_x: 1
                    size_hint_y: None
                    height: dp(136)
                    radius: [dp(12), ]
                    md_bg_color: 0.8, 0.8, 0.8, 0.5
                    padding: dp(4)
                    elevation: 0

                    MDBoxLayout:
                        orientation: 'vertical'
                        spacing: dp(4)
                        size_hint_x: 1

                        PeriodSegmentButton:
                            text: "Miesiąc"
                            selected: root.selected_period == "Miesiąc"
                            on_release: root.set_period("Miesiąc")
                            halign: "center"
                            valign: "middle"
                            font_size: dp(15)
                        PeriodSegmentButton:
                            text: "Tydzień"
                            selected: root.selected_period == "Tydzień"
                            on_release: root.set_period("Tydzień")
                            halign: "center"
                            valign: "middle"
                            font_size: dp(15)
                        PeriodSegmentButton:
                            text: "Dzień"
                            selected: root.selected_period == "Dzień"
                            on_release: root.set_period("Dzień")
                            halign: "center"
                            valign: "middle"
                            font_size: dp(15)

                MDLabel:
                    text: root.total_time_text
                    halign: "right"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    size_hint_y: None
                    height: dp(22)

                # --- Centered pie + caption ---
                AnchorLayout:
                    size_hint_y: None
                    height: dp(220) + dp(12) + dp(52)

                    MDBoxLayout:
                        orientation: 'vertical'
                        spacing: dp(12)
                        size_hint: None, None
                        width: dp(260)
                        height: dp(220) + dp(12) + dp(52)

                        PieChart:
                            id: pie_chart
                            size_hint: None, None
                            size: dp(220), dp(220)
                            pos_hint: {"center_x": .5}
                            opacity: 1 if root.has_data else 0.25

                        MDLabel:
                            text: root.empty_hint_text if not root.has_data else "Łączny czas spędzony na projektach"
                            halign: "center"
                            valign: "middle"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 0.95
                            size_hint_y: None
                            height: dp(48)
                            text_size: dp(250), None
                            shorten: True
                            shorten_from: "right"

                # --- Details: header + rows from set_statistics_rows() ---
                MDCard:
                    id: stats_card
                    size_hint_y: None
                    height: root.stats_card_height
                    radius: [dp(20)]
                    md_bg_color: 0.65, 0.45, 0.9, 1
                    padding: dp(14)
                    spacing: dp(10)
                    orientation: 'vertical'
                    elevation: 0

                    MDBoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: dp(26)
                        spacing: dp(6)

                        MDLabel:
                            text: "Projekt"
                            font_style: "Caption"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 0.85
                            size_hint_x: 1
                            halign: "left"
                            valign: "middle"
                        MDLabel:
                            text: ""
                            size_hint_x: 1
                        MDLabel:
                            text: "Czas"
                            font_style: "Caption"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 0.85
                            size_hint_x: 1
                            halign: "right"
                            valign: "middle"

                    MDBoxLayout:
                        id: stats_rows_container
                        orientation: "vertical"
                        spacing: dp(10)
                        size_hint_y: None
                        height: self.minimum_height

                    MDLabel:
                        text: "Brak danych — zatrzymaj timer w projekcie, aby dodać czas."
                        opacity: 0 if root.has_data else 1
                        halign: "center"
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 0.75
                        font_size: sp(13)
                        size_hint_y: None
                        height: dp(48) if not root.has_data else 0
                        text_size: self.width, None

        # --- Bottom bar (same structure as home) ---
        MDFloatLayout:
            size_hint: 1, None
            height: dp(90)

            MDCard:
                size_hint: 0.96, 0.75
                pos_hint: {'center_x': 0.5, 'y': 0.1}
                radius: [dp(25), ]
                elevation: 4
                md_bg_color: 1, 1, 1, 1

                MDBoxLayout:
                    AnchorLayout:
                        anchor_x: 'center'
                        anchor_y: 'center'
                        MDIconButton:
                            icon: "home-outline"
                            icon_size: dp(45)
                            on_release: app.root.current = "home"

                    Widget:

                    AnchorLayout:
                        anchor_x: 'center'
                        anchor_y: 'center'
                        MDIconButton:
                            icon: "chart-arc"
                            icon_size: dp(45)
                            on_release: app.root.current = "statistics"

            ClickableAnchorLayout:
                size_hint: None, None
                size: dp(140), dp(65)
                pos_hint: {'center_x': 0.5, 'center_y': 0.65}
                on_release: app.root.current = "add_project"
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex(app.theme_card_bg)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(20)]

                MDIcon:
                    icon: "plus"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    icon_size: dp(55)
                    adaptive_size: True
