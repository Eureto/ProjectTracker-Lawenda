#:import utils kivy.utils
#:import Label kivy.uix.label.Label
#:import BoxLayout kivy.uix.boxlayout.BoxLayout
#:import ProjectNoteRow screens.project_info.ProjectNoteRow
#:import TimeGoalTrackRow screens.project_info.TimeGoalTrackRow
#:import CarProgressButton screens.project_info.CarProgressButton
#:import ChecklistGoalRow screens.project_info.ChecklistGoalRow
#:import StageItemRow screens.project_info.StageItemRow
#:import StageTextTap screens.project_info.StageTextTap
#:import UnderlineTextBlock screens.project_info.UnderlineTextBlock
#:import TimelineSpine screens.project_info.TimelineSpine
#:import StatusCircleButton screens.project_info.StatusCircleButton
#:import EtapyPlusRow screens.project_info.EtapyPlusRow
#:import EtapyPlusSpine screens.project_info.EtapyPlusSpine
#:import ZrobioneSection screens.project_info.ZrobioneSection
#:import ZrobioneHeaderBar screens.project_info.ZrobioneHeaderBar

# ---------------------------------------------------------------------------
# DEFINICJE ELEMENTÓW INTERFEJSU
# ---------------------------------------------------------------------------
# Poniższe sekcje opisują poszczególne "szablony" (czyli gotowe elementy
# wizualne) używane na ekranie szczegółów projektu. Każdy szablon grupuje
# ze sobą kilka elementów (np. etykietę, przycisk, pole tekstowe), które
# razem tworzą jeden logiczny blok.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# WIERSZ NOTATKI – wyświetla treść notatki z przyciskiem usuwania
# ---------------------------------------------------------------------------
# "orientation: horizontal" – elementy są ułożone obok siebie: pole z tekstem
# po lewej, przycisk "×" po prawej.
# "size_hint_y: None" – wysokość nie jest procentowa tylko ustalana przez kod.
# "spacing" – odstęp między elementami w pikselach.
<ProjectNoteRow>:
    orientation: "horizontal"
    spacing: dp(10)
    size_hint_y: None

    # Białe pudełko z zaokrąglonymi rogami – tło dla tekstu notatki
    # "size_hint_x: 1" – zajmij całą dostępną szerokość (po odjęciu przycisku).
    # "canvas.before:" – rysuje białe tło przed tekstem.
    # "RoundedRectangle" – prostokąt z zaokrąglonymi rogami (tutaj 12dp każdy róg).
    MDBoxLayout:
        size_hint_x: 1
        size_hint_y: 1
        padding: dp(2)
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(12), dp(12), dp(12), dp(12)]

        # "ScrollView" – pozwala przewijać tekst notatki jeśli jest za długi.
        # "do_scroll_x: False" – przewijanie tylko w pionie (nie w poziomie).
        # "bar_width: 0" – ukryj pasek przewijania (design).
        ScrollView:
            id: note_scroll
            size_hint: 1, 1
            do_scroll_x: False
            bar_width: 0

            # "MDLabel" – etykieta z tekstem notatki.
            # "height: self.texture_size[1]" – wysokość dopasowana do treści
            # (texture_size to rozmiar faktycznie narysowanego tekstu).
            # "max_lines: 0" – brak limitu linii.
            # "line_height: 1.2" – odstęp między liniami (1.2 = 120% czcionki).
            MDLabel:
                id: note_label
                text: root.display_text
                halign: "left"
                valign: "top"
                theme_text_color: "Custom"
                text_color: (0.45, 0.45, 0.48, 1) if not root.display_text else (0.12, 0.12, 0.12, 1)
                font_size: sp(14)
                padding: dp(8), dp(6), dp(8), dp(6)
                size_hint_y: None
                height: self.texture_size[1]
                shorten: False
                max_lines: 0
                line_height: 1.2

    # Przycisk "×" do usunięcia notatki (fioletowe kółko)
    # "background_normal: ''" i "background_color: 0,0,0,0" – usuwa domyślne
    # tło przycisku, bo rysujemy własne (fioletowe koło przez canvas.before).
    # "Ellipse" – rysuje owal/koło. "self.center_x/y" – środek przycisku.
    Button:
        id: delete_btn
        size_hint_x: None
        size_hint_y: 1
        width: dp(48)
        text: "×"
        color: 1, 1, 1, 1
        font_size: sp(22)
        bold: True
        background_normal: ""
        background_color: 0, 0, 0, 0
        on_press: root.request_delete()
        canvas.before:
            Color:
                rgba: utils.get_color_from_hex("#7e57c2")
            Ellipse:
                pos: self.center_x - dp(18), self.center_y - dp(18)
                size: dp(36), dp(36)

# ---------------------------------------------------------------------------
# WIERSZ Z CELAMI CZASOWYMI – pokazuje samochodzik, timer i informacje o celu
# ---------------------------------------------------------------------------
# Ten element wyświetla pasek postępu dla celu czasowego. Postęp jest
# reprezentowany przez samochodzik jadący po linii od lewej do prawej.
# Po osiągnięciu 100% samochodzik jeździ w tę i z powrotem.
#
# "RelativeLayout" – umożliwia swobodne pozycjonowanie dzieci względem siebie
# (tutaj: samochodzik na linii, flaga na mecie, czas nad autem).
# "pos_hint" – pozycjonowanie procentowe: {"right": 1} = prawa krawędź na 100%.

<TimeGoalTrackRow>:
    orientation: "horizontal"
    spacing: dp(10)
    size_hint_y: None
    height: dp(140)

    MDBoxLayout:
        orientation: "vertical"
        size_hint_x: 1
        spacing: dp(4)

        # Pasek z samochodzikiem – "RelativeLayout" nakłada elementy na siebie
        RelativeLayout:
            id: goal_track
            size_hint_y: None
            height: dp(110)

            # "canvas.before:" – rysuje czarną linię (drogę) pod samochodzikiem
            # "Line" – linia między punktami (points: [x1,y1, x2,y2])
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 1
                Line:
                    width: dp(2.5)
                    points: [dp(8), dp(16), self.width - dp(8), dp(16)]

            # Samochodzik – zmienia obrazek gdy cel jest aktywny (jedzie) lub nieaktywny (śpi)
            # "pos_hint: {"center_x": root.car_hint_x}" – pozycja X samochodzika
            # zależy od postępu (0% = lewo, 100% = prawo).
            # "Scale:" – odwraca samochodzik w poziomie (x: -1) gdy jedzie w lewo.
            CarProgressButton:
                id: car_btn
                source: root.car_source_active if root.tracking_active else root.car_source_idle
                size_hint: None, None
                size: dp(96), dp(68)
                allow_stretch: True
                keep_ratio: True
                pos_hint: {"center_x": root.car_hint_x}
                y: -dp(9)
                on_release: root.on_car_button_release()
                canvas.before:
                    PushMatrix
                    Scale:
                        x: root.car_scale_x
                        y: 1
                        origin: self.center
                canvas.after:
                    PopMatrix

            # Flaga na mecie (prawa strona) – ikona szachownicy
            # "Scale: x: -1" – odwraca ikonę (bo domyślnie patrzy w lewo).
            MDIcon:
                icon: "flag-checkered"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                icon_size: dp(22)
                adaptive_size: True
                pos_hint: {"right": 1, "top": 0.42}
                canvas.before:
                    PushMatrix
                    Scale:
                        x: -1
                        y: 1
                        origin: self.center
                canvas.after:
                    PopMatrix

            # Czas jaki upłynął (wyświetlany nad samochodzikiem)
            # "opacity: 1 if root.elapsed_text else 0" – widoczny tylko gdy
            # minęła co najmniej 1 sekunda.
            MDLabel:
                text: root.elapsed_text
                opacity: 1 if root.elapsed_text else 0
                font_size: sp(11)
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                halign: "center"
                valign: "middle"
                max_lines: 1
                shorten: False
                text_size: (dp(200), None)
                size_hint: None, None
                height: dp(16)
                width: max(dp(44), self.texture_size[0])
                pos_hint: {"center_x": root.car_hint_x}
                y: car_btn.top - self.height - dp(2)

        # Dolny pasek: nazwa celu i informacja o przedziale czasu (np. "1h / tydzień")
        # "text_size: (dp(200), None)" – ogranicza szerokość tekstu do 200dp
        # (zapewnia prawidłowe zawijanie i pozycjonowanie).
        BoxLayout:
            id: goal_caption_box
            orientation: "horizontal"
            size_hint_y: None
            height: dp(26)
            padding: [dp(6), dp(2), dp(8), dp(2)]
            spacing: dp(8)

            Label:
                id: goal_title_lbl
                text: root.title_text
                color: 1, 1, 1, 1
                font_size: sp(14)
                size_hint_x: 1
                size_hint_y: 1
                text_size: (dp(200), None)
                halign: "left"
                valign: "middle"
                shorten: True
                shorten_from: "right"

            Label:
                id: goal_period_lbl
                text: root.goal_text
                color: 1, 1, 1, 1
                font_size: sp(13)
                size_hint_x: None
                size_hint_y: 1
                width: dp(80)
                text_size: (dp(80), None)
                halign: "right"
                valign: "middle"

    # Prawa kolumna: procent postępu i przycisk usuwania
    MDBoxLayout:
        orientation: "vertical"
        size_hint_x: None
        width: dp(48)
        spacing: dp(8)
        padding: [0, dp(2), 0, 0]

        AnchorLayout:
            size_hint_y: None
            height: dp(52)
            anchor_x: "center"
            anchor_y: "top"

            RelativeLayout:
                size_hint: None, None
                size: dp(46), dp(48)

                # Karta z procentem postępu (zmienia kolor na zielony po osiągnięciu 100%)
                # "md_bg_color: root.percent_card_color" – kolor zmienia się dynamicznie.
                MDCard:
                    id: percent_card
                    size_hint: None, None
                    size: dp(46), dp(40)
                    pos: 0, 0
                    radius: [dp(8), dp(8), dp(8), dp(8)]
                    md_bg_color: root.percent_card_color
                    elevation: 0

                    MDLabel:
                        text: root.percent_text
                        halign: "center"
                        valign: "middle"
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1
                        font_size: sp(13)
                        bold: True

                # Korona – pojawia się gdy cel jest ukończony
                # "opacity: 1 if root.is_goal_complete else 0" – widoczna
                # tylko gdy postęp osiągnął 100%.
                # "nocache: True" – nie przechowuj w pamięci (obrazek może
                # się zmieniać dynamicznie).
                Image:
                    source: root.crown_source
                    opacity: 1 if root.is_goal_complete else 0
                    size_hint: None, None
                    size: dp(26), dp(26)
                    allow_stretch: True
                    keep_ratio: True
                    pos_hint: {"center_x": 0.5}
                    y: dp(30)
                    nocache: True

        # Czerwony przycisk usuwania celu
        AnchorLayout:
            size_hint_y: None
            height: dp(44)
            anchor_x: "center"
            anchor_y: "top"

            Button:
                id: delete_btn
                size_hint: None, None
                size: dp(40), dp(40)
                text: "×"
                color: 1, 1, 1, 1
                font_size: sp(22)
                bold: True
                background_normal: ""
                background_color: 0, 0, 0, 0
                on_press: root.request_delete()
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex("#c62828")
                    Ellipse:
                        pos: self.pos
                        size: self.size

# ---------------------------------------------------------------------------
# PRZYCISK "+" W NAGŁÓWKACH SEKCJI
# ---------------------------------------------------------------------------
# Mały przezroczysty przycisk z ikoną plusa, używany do dodawania nowych
# elementów (notatek, celów, etapów).
# "SectionHeaderAction@MDIconButton" – tworzy nowy szablon na bazie MDIconButton.

<SectionHeaderAction@MDIconButton>:
    size_hint: None, None
    width: dp(48)
    height: dp(28)
    theme_text_color: "Custom"
    text_color: 1, 1, 1, 1
    icon_size: dp(24)
    md_bg_color: 0, 0, 0, 0

# ---------------------------------------------------------------------------
# NAGŁÓWEK SEKCJI "ZROBIONE" (można go zwinąć/rozwinąć)
# ---------------------------------------------------------------------------
# Pasek z napisem "Zrobione" i strzałką (chevron). Kliknięcie rozwija
# lub zwija listę ukończonych celów.
# "Widget size_hint_x: 1" – pusty element który rozciąga się, odpychając
# chevron do prawej strony (wypełniacz).

<ZrobioneHeaderBar>:
    size_hint_y: None
    height: dp(28)
    MDLabel:
        id: zrobione_title
        text: "Zrobione"
        font_size: sp(14)
        bold: True
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        halign: "left"
        valign: "middle"
        text_size: self.size
    Widget:
        size_hint_x: 1
    AnchorLayout:
        size_hint_x: None
        size_hint_y: 1
        width: dp(48)
        anchor_x: "center"
        anchor_y: "center"
        MDIcon:
            id: zrobione_chevron
            icon: "chevron-down"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            icon_size: dp(24)
            size_hint: None, None

# ---------------------------------------------------------------------------
# SEKCJA "ZROBIONE" – pojemnik na ukończone cele z listy celów
# ---------------------------------------------------------------------------
# Gdy użytkownik zaznaczy cel jako zrobiony, cel przenosi się tutaj.
# Sekcję można zwinąć klikając w nagłówek.
# "size_hint_y: None" – wysokość sekcji zależy od liczby celów w środku.

<ZrobioneSection>:
    orientation: "vertical"
    spacing: dp(8)
    size_hint_y: None

    ZrobioneHeaderBar:
        id: zrobione_header

    MDBoxLayout:
        id: checklist_done_list
        orientation: "vertical"
        spacing: dp(14)
        size_hint_y: None

# ---------------------------------------------------------------------------
# WIERSZ Z CELEM Z LISTY CELÓW (z numerem, tekstem i przyciskiem statusu)
# ---------------------------------------------------------------------------
# Każdy cel na liście ma swój numer, opis tekstowy i kółko do oznaczania
# jako zrobiony/niezrobiony.
# "UnderlineTextBlock" – własny element: biały tekst z linią pod spodem.
# "StatusCircleButton" – okrągły przycisk zmieniający stan (puste/kolorowe kółko).
# "compact_rule: True" – mniejszy odstęp między tekstem a linią.

<ChecklistGoalRow>:
    size_hint_y: None
    valign: "middle"
    AnchorLayout:
        id: index_anchor
        size_hint_x: None
        size_hint_y: None
        width: dp(22) if root.index_label else 0
        opacity: 1 if root.index_label else 0
        anchor_x: "right"
        anchor_y: "center"
        Label:
            id: index_lbl
            text: root.index_label
            size_hint: None, None
            font_size: sp(14)
            color: 1, 1, 1, 1
            halign: "right"
            valign: "middle"
            shorten: False
    UnderlineTextBlock:
        id: underline_block
        compact_rule: True
        size_hint_x: 1
        size_hint_y: None
        text: root.display_text
    AnchorLayout:
        id: status_anchor
        size_hint_x: None
        size_hint_y: None
        width: dp(48)
        anchor_x: "center"
        anchor_y: "center"
        StatusCircleButton:
            id: status_btn
            show_crown: False
            white_style: True
            size_hint: None, None
            size: dp(26), dp(26)

# ---------------------------------------------------------------------------
# WIERSZ ETAPU NA OSI CZASU (krok lub podkrok)
# ---------------------------------------------------------------------------
# Każdy etap na osi czasu to wiersz z: pionową linią (spiną), tekstem
# i kółkiem statusu. Podkroki są wcięte i mają strzałkę zamiast kropki.
# "is_sub" – czy to podkrok (True = mniejsza czcionka, strzałka zamiast kropki).
# "is_first" – czy to pierwszy element (linia zaczyna się od góry).
# "is_last" – czy to ostatni element (linia kończy się, a nie ciągnie dalej).

<StageItemRow>:
    TimelineSpine:
        id: spine
    Widget:
        # Odstęp który przesuwa tekst podkroku w prawo, aby był za strzałką
        id: sub_arrow
        size_hint_x: None
        width: dp(16) if root.is_sub else 0
        opacity: 0
    StageTextTap:
        id: tap_area
        size_hint_x: 1
        on_release: root._open_editor()
        UnderlineTextBlock:
            id: underline_block
            size_hint_x: 1
            text: root.display_text
            font_size: sp(13) if root.is_sub else sp(16)
            show_rule: not root.is_last
    StatusCircleButton:
        id: status_btn
        show_crown: False
        white_style: True

# ---------------------------------------------------------------------------
# WIERSZ "DODAJ KROK" – przycisk na dole osi czasu etapów
# ---------------------------------------------------------------------------
# Ten wiersz pojawia się na końcu listy etapów. Kliknięcie otwiera
# formularz do dodania nowego kroku.
# "EtapyPlusSpine" – rysuje linię z fioletowym kółkiem z plusem.
# "connect_top" – czy rysować linię łączącą z poprzednim elementem.

<EtapyPlusRow>:
    EtapyPlusSpine:
        id: plus_spine
        size_hint_x: None
        width: dp(22)
        connect_top: root.connect_top
    MDLabel:
        text: "Dodaj krok"
        font_size: sp(13)
        bold: True
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 0.8
        valign: "middle"
        halign: "left"
        size_hint_x: 1
        text_size: self.size

# ---------------------------------------------------------------------------
# EKRAN SZCZEGÓŁÓW PROJEKTU (główna zawartość tego pliku)
# ---------------------------------------------------------------------------
# To jest najważniejszy ekran w aplikacji. Zawiera:
# - Notatki – lista notatek związanych z projektem
# - Czas – stoper do mierzenia czasu pracy nad projektem
# - Cele czasowe – paski postępu z samochodzikiem
# - Lista celów – checklista zadań do zrobienia
# - Etapy – oś czasu z krokami i podkrokami
# Na dole znajduje się pasek nawigacyjny (taki sam jak na ekranie głównym)
# z przyciskiem ustawień (trybik) zamiast "+".
#
# "FloatLayout" – nakłada na siebie elementy. Tutaj: główna zawartość
# (przewijana) i dolny pasek (na stałe na dole).
# "padding: [dp(18), dp(28), dp(18), dp(67)]" – odstępy od krawędzi,
# w tym 67dp na dole dla paska nawigacyjnego.
# "texture_size[1]" – wysokość tekstu po narysowaniu (używana do
# dynamicznego ustawiania wysokości etykiety tytułu).

<ProjectInfoScreen>:
    md_bg_color: utils.get_color_from_hex(app.theme_bg)

    FloatLayout:
        MDBoxLayout:
            orientation: "vertical"
            size_hint: 1, 1
            padding: [dp(18), dp(28), dp(18), dp(67)]

            # Nazwa projektu na górze ekranu
            # "height: self.texture_size[1] + dp(4)" – wysokość dopasowana
            # do faktycznie narysowanego tekstu (tekst może być krótki lub długi).
            MDLabel:
                text: root.project_title or "Projekt"
                font_size: sp(17)
                bold: True
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                halign: "center"
                valign: "middle"
                shorten: True
                shorten_from: "right"
                size_hint_y: None
                height: self.texture_size[1] + dp(4)

            Widget:
                size_hint_y: None
                height: dp(10)

            # Przewijana zawartość – wszystkie sekcje
            # "ScrollView" – umożliwia przewijanie gdy zawartość jest dłuższa niż ekran.
            # "do_scroll_x: False" – tylko przewijanie w pionie.
            # "size_hint_y: 1" – zajmij całą dostępną wysokość.
            # "bar_width: 0" – ukryj pasek przewijania.
            ScrollView:
                do_scroll_x: False
                size_hint_y: 1
                bar_width: 0

                # "adaptive_height" nie jest ustawione – zamiast tego używamy
                # "height: self.minimum_height" aby wysokość dopasowywała się
                # do sumy wysokości wszystkich dzieci.
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(8)
                    size_hint_y: None
                    height: self.minimum_height
                    padding: [0, dp(20), 0, dp(8)]

                    # ── SEKCJA: Notatki ──
                    # "MDBoxLayout" – pionowe pudełko. "height: self.minimum_height"
                    # – wysokość dopasowuje się do zawartości.
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(12)
                        size_hint_y: None
                        height: self.minimum_height

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(48)
                            MDLabel:
                                text: "Notatki"
                                font_size: sp(34)
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 1, 1, 1, 1
                                halign: "left"
                                valign: "middle"
                                text_size: self.size
                            Widget:
                                size_hint_x: 1
                            SectionHeaderAction:
                                icon: "plus"
                                on_release: root.open_add_note_sheet()

                        MDBoxLayout:
                            id: notes_list
                            orientation: "vertical"
                            spacing: dp(12)
                            size_hint_y: None
                            height: self.minimum_height

                    Widget:
                        size_hint_y: None
                        height: dp(28)

                    # ── SEKCJA: Czas (stoper) ──
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(14)
                        size_hint_y: None
                        height: self.minimum_height

                        MDLabel:
                            text: "Czas"
                            font_size: sp(34)
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            halign: "left"
                            size_hint_y: None
                            height: dp(48)

                        # Wyświetlacz stopera (HH:MM:SS)
                        # "font_size: sp(44)" – duża, czytelna czcionka.
                        MDLabel:
                            text: root.timer_display
                            font_size: sp(44)
                            bold: False
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            halign: "center"
                            size_hint_y: None
                            height: self.texture_size[1]

                        # Przycisk Start / Stop
                        # Przycisk zmienia kolor: zielony (Start) lub czerwony (Stop).
                        # "canvas.before:" – rysuje zaokrąglony prostokąt jako tło
                        # przycisku (zamiast domyślnego, bo background_normal jest '').
                        AnchorLayout:
                            size_hint_y: None
                            height: dp(44)
                            anchor_x: "center"
                            anchor_y: "center"

                            Button:
                                text: root.timer_button_caption
                                font_size: sp(16)
                                bold: False
                                color: 1, 1, 1, 1
                                size_hint: None, None
                                width: self.texture_size[0] + dp(48)
                                height: dp(38)
                                background_normal: ""
                                background_color: 0, 0, 0, 0
                                on_release: root.toggle_timer()
                                canvas.before:
                                    Color:
                                        rgba: utils.get_color_from_hex("#43a047") if not root.timer_running else utils.get_color_from_hex("#e53935")
                                    RoundedRectangle:
                                        pos: self.pos
                                        size: self.size
                                        radius: [dp(19), dp(19), dp(19), dp(19)]

                    Widget:
                        size_hint_y: None
                        height: dp(28)

                    # ── SEKCJA: Cele czasowe (z samochodzikiem) ──
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(16)
                        size_hint_y: None
                        height: self.minimum_height

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(48)
                            MDLabel:
                                text: "Cele czasowe"
                                font_size: sp(34)
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 1, 1, 1, 1
                                halign: "left"
                                valign: "middle"
                                text_size: self.size
                            Widget:
                                size_hint_x: 1
                            SectionHeaderAction:
                                icon: "plus"
                                on_release: root.on_goals_add_clicked()

                        MDBoxLayout:
                            id: goals_list
                            orientation: "vertical"
                            spacing: dp(16)
                            size_hint_y: None
                            height: self.minimum_height

                    Widget:
                        size_hint_y: None
                        height: dp(28)

                    # ── SEKCJA: Lista celów (checklista) ──
                    MDBoxLayout:
                        id: lista_celow_box
                        orientation: "vertical"
                        spacing: dp(14)
                        size_hint_y: None
                        height: self.minimum_height

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(48)
                            MDLabel:
                                text: "Lista celów"
                                font_size: sp(34)
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 1, 1, 1, 1
                                halign: "left"
                                valign: "middle"
                                text_size: self.size
                            Widget:
                                size_hint_x: 1
                            SectionHeaderAction:
                                icon: "plus"
                                on_release: root.open_add_checklist_goal_sheet()

                        MDBoxLayout:
                            id: checklist_goals_list
                            orientation: "vertical"
                            spacing: dp(14)
                            size_hint_y: None
                            height: self.minimum_height
                            on_minimum_height: self.height = self.minimum_height

                        # Sekcja "Zrobione" – przenoszone są tu ukończone cele
                        ZrobioneSection:
                            id: zrobione_section
                            done_count: 0

                    Widget:
                        size_hint_y: None
                        height: dp(28)

                    # ── SEKCJA: Etapy (oś czasu) ──
                    MDBoxLayout:
                        orientation: "vertical"
                        spacing: dp(12)
                        size_hint_y: None
                        height: self.minimum_height

                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(48)
                            MDLabel:
                                text: "Etapy"
                                font_size: sp(34)
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 1, 1, 1, 1
                                halign: "left"
                                valign: "middle"
                                text_size: self.size
                            Widget:
                                size_hint_x: 1
                            SectionHeaderAction:
                                icon: "plus"
                                on_release: root.open_add_etapy_group_sheet()

                        # Przewijane poziomo "żetony" (chipsy) z nazwami grup etapów
                        # "ScrollView" z "do_scroll_x: True" – przewijanie w poziomie.
                        # "height: dp(40)" – stała wysokość paska z żetonami.
                        ScrollView:
                            size_hint_y: None
                            height: dp(40)
                            do_scroll_x: True
                            do_scroll_y: False
                            bar_width: 0

                            MDBoxLayout:
                                id: etapy_chips_box
                                orientation: "horizontal"
                                spacing: dp(8)
                                size_hint_x: None
                                width: self.minimum_width
                                height: dp(36)
                                padding: [0, dp(2), 0, dp(2)]

                        # Oś czasu z krokami i podkrokami
                        # "spacing: dp(2)" – mały odstęp między elementami osi.
                        MDBoxLayout:
                            id: etapy_timeline_list
                            orientation: "vertical"
                            spacing: dp(2)
                            size_hint_y: None
                            height: self.minimum_height
                            padding: [0, dp(4), 0, 0]

        # Dolny pasek nawigacyjny (taki sam jak na ekranie głównym)
        # Środkowy przycisk to ustawienia (trybik) zamiast "+".
        # "MDFloatLayout" umieszczony na dole ("pos_hint: {"y": 0}").
        # "height: dp(60)" – wysokość paska nawigacji.
        MDFloatLayout:
            size_hint: 1, None
            height: dp(60)
            pos_hint: {"center_x": 0.5, "y": 0}

            MDCard:
                size_hint: 1, 1
                pos_hint: {"x": 0, "y": 0}
                radius: [dp(25), dp(25), 0, 0]
                elevation: 4
                md_bg_color: 1, 1, 1, 1

                MDBoxLayout:
                    AnchorLayout:
                        anchor_x: "center"
                        anchor_y: "center"
                        MDIconButton:
                            icon: "home-outline"
                            icon_size: dp(30)
                            on_release: root.go_home()

                    Widget:

                    AnchorLayout:
                        anchor_x: "center"
                        anchor_y: "center"
                        MDIconButton:
                            icon: "chart-arc"
                            icon_size: dp(30)
                            on_release: root.go_statistics()

            # Przycisk ustawień (trybik) – unosi się nad paskiem nawigacyjnym
            # "size: dp(120), dp(56)" – szeroki, niski prostokąt.
            # "pos_hint: {"center_y": 0.67}" – 67% od dołu, unosi się nad paskiem.
            ClickableAnchorLayout:
                size_hint: None, None
                size: dp(120), dp(56)
                pos_hint: {"center_x": 0.5, "center_y": 0.67}
                on_release: root.open_project_settings()
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex(app.theme_card_bg)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(18)]

                MDIcon:
                    icon: "cog-outline"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    icon_size: dp(48)
                    adaptive_size: True